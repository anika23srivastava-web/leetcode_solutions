class Solution:
    def majorityElement(self, nums: List[int]) -> int:
        candidate = None
        count = 0
        
        for num in nums:
            # If count is 0, we choose a new candidate
            if count == 0:
                candidate = num
            
            # If current number matches the candidate, increment; otherwise decrement
            count += 1 if num == candidate else -1
            
        return candidate
